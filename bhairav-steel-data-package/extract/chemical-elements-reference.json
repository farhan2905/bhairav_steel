  "gradeNamingConventions": {
    "ferroManganese": {
      "pattern": "HC/MC/LC FeMn XX%",
      "examples": ["HC FeMn Grade 1 (65-70% Mn)", "LC FeMn (0.10% C max)"],
      "notes": "HC = High Carbon, MC = Medium Carbon, LC = Low Carbon"
    },
    "ferroSilicon": {
      "pattern": "FeSi XX%",
      "examples": ["FeSi75", "FeSi50"],
      "notes": "Number indicates minimum silicon percentage"
    },
    "ferroChrome": {
      "pattern": "HC/LC FeCr XX% C max",
      "examples": ["HC FeCr 60% Cr 2% Si 9% C", "LC FeCr 65% Cr 0.15% C"],
      "notes": "Low carbon grades specify max carbon content"
    },
    "silicoManganese": {
      "pattern": "HC/MC/LC SiMn XX%",
      "examples": ["HC SiMn 70% Mn 18% Si", "LC SiMn 65% Mn 28% Si"],
      "notes": "Contains both manganese and silicon"
    }
  },
